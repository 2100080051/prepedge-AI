# PrepEdge AI Backend Environment Template
# ⚠️ COPY TO .env AND FILL VALUES. NEVER COMMIT .env!
# Rotate all keys before production.

# === Database Configuration ===
# Production: PostgreSQL on Azure
# Development: SQLite (local)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# === JWT Configuration ===
SECRET_KEY=your-super-secret-key-min-32-chars-generate-with-openssl-rand-hex-32!
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# === LLM API Keys (Dual-key setup for failover/load-balancing) ===
# NVIDIA NIM API (free tier available)
OPENAI_API_KEY=nvapi-your-nvidia-key-here
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1

# OpenRouter (2 keys for redundancy)
OPENROUTER_API_KEY_1=sk-or-v1-your-first-openrouter-key
OPENROUTER_API_KEY_2=sk-or-v1-your-second-openrouter-key-fallback

# Groq (2 keys for redundancy and fast inference)
GROQ_API_KEY_1=gsk-your-first-groq-key
GROQ_API_KEY_2=gsk-your-second-groq-key-fallback

# Pollinations AI (image generation)
POLLINATIONS_API_KEY=pk-your-pollinations-key

# === Email Configuration ===
RESEND_API_KEY=re_your-resend-api-key-here
RESEND_FROM_EMAIL=noreply@yourdomain.com

# === Google OAuth (Optional) ===
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# === Razorpay Payments (Optional) ===
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-secret

# === Application Configuration ===
ENVIRONMENT=production  # development|production
DEBUG=false
FRONTEND_URL=https://prepedgeai.in
CORS_ORIGINS=*

# === Optional: Monitoring & Analytics ===
# DATADOG_API_KEY=your-datadog-key
# SENTRY_DSN=your-sentry-dsn
