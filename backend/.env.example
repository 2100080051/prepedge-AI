# PrepEdge AI Backend Environment Template
# ⚠️ COPY TO .env AND FILL VALUES. NEVER COMMIT .env!
# Rotate all keys before production.

# Database (Prod: PostgreSQL)
DATABASE_URL=sqlite:///./prepedge.db

# JWT (Generate: openssl rand -hex 32)
SECRET_KEY=your-64-char-secret-key-here-change-now!

# LLM Providers (All optional - fallbacks exist)
OPENAI_API_KEY=your-nvidia-nim-key
OPENROUTER_API_KEY=sk-or-v1-your-key
GROQ_API_KEY=gsk-your-groq-key
POLLINATIONS_API_KEY=your-pollinations-key

# Auth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-secret

# Payments
RAZORPAY_KEY_ID=your-razorpay-id
RAZORPAY_KEY_SECRET=your-secret

# Others
ENVIRONMENT=development  # production
DEBUG=False
FRONTEND_URL=http://localhost:3000
